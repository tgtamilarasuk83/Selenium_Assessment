package assessment;

import java.time.Duration;
import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.edge.EdgeDriver;
import org.openqa.selenium.interactions.Actions;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class DemoblazeTest {

    public static void main(String[] args) {

        // Launch browser
        WebDriver driver = new EdgeDriver();
        driver.manage().window().maximize();

        // Implicit wait
        driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));

        // Open URL
        driver.get("https://demoblaze.com/");

        // Explicit wait
        WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(15));

        // ================= LOGIN =================
        driver.findElement(By.id("login2")).click();

        wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("loginusername")));
        driver.findElement(By.id("loginusername")).sendKeys("arasu");
        driver.findElement(By.id("loginpassword")).sendKeys("arasu");

        driver.findElement(By.xpath("//button[text()='Log in']")).click();

        // Validate login
        WebElement welcomeText = wait.until(
                ExpectedConditions.visibilityOfElementLocated(
                        By.xpath("//a[contains(text(),'Welcome')]")));

        if (welcomeText.getText().contains("arasu")) {
            System.out.println("Login Successful");
        }

        // ================= CATEGORY NAVIGATION =================
        WebElement laptops = wait.until(
                ExpectedConditions.elementToBeClickable(By.xpath("//a[text()='Laptops']")));
        laptops.click();

        // Get all laptop names
        List<WebElement> elements = driver.findElements(By.xpath("//a[@class='hrefch']"));

        List<String> productNames = new ArrayList<>();

        for (WebElement e : elements) {
            productNames.add(e.getText());
        }

        // Sort product names
        Collections.sort(productNames);

        for (String name : productNames) {
            System.out.println("Laptop: " + name);
        }

        // ================= ADD PRODUCT =================
        driver.findElement(By.xpath("//a[text()='MacBook Pro']")).click();

        wait.until(ExpectedConditions.elementToBeClickable(
                By.xpath("//a[text()='Add to cart']"))).click();

        System.out.println("Product added to cart");

        // ================= CART =================
        driver.findElement(By.id("cartur")).click();

        wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.xpath("//h2[text()='Products']")));

        // ================= PLACE ORDER =================
        driver.findElement(By.xpath("//button[text()='Place Order']")).click();

        wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("name")));

        driver.findElement(By.id("name")).sendKeys("John Doe");
        driver.findElement(By.id("country")).sendKeys("India");
        driver.findElement(By.id("city")).sendKeys("Bangalore");
        driver.findElement(By.id("card")).sendKeys("1234567812345678");
        driver.findElement(By.id("month")).sendKeys("04");
        driver.findElement(By.id("year")).sendKeys("2026");

        driver.findElement(By.xpath("//button[text()='Purchase']")).click();

        // ================= CONFIRMATION =================
        WebElement confirmation = wait.until(
                ExpectedConditions.visibilityOfElementLocated(
                        By.xpath("//div[contains(@class,'sweet-alert')]")));

        String text = confirmation.getText();

        if (text.contains("Id")) {
            System.out.println("Order placed successfully");

            String[] lines = text.split("\n");

            for (String line : lines) {
                if (line.contains("Id")) {
                    System.out.println("Order ID: " + line.split(":")[1].trim());
                }
                if (line.contains("Amount")) {
                    System.out.println("Amount: " + line.split(":")[1].trim());
                }
                if (line.contains("Date")) {
                    System.out.println("Date: " + line.split(":")[1].trim());
                }
            }
        } else {
            System.out.println("Order failed");
        }

        // Close browser
        driver.quit();
    }
}
